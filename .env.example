# ─────────────────────────────────────────────────────────────────────────────
# AIP PPC Assistant — environment template. Copy to `.env` and fill in.
# `docker compose up --build` reads this file automatically.
# ─────────────────────────────────────────────────────────────────────────────

# --- Production deployment (see DEPLOYMENT.md) ---
# Public hostname served by the Caddy HTTPS proxy in docker-compose.prod.yml.
# Use `localhost` for a local smoke test of the production stack.
DOMAIN=localhost

# --- Database (Postgres on Colima) ---
DB_URL=jdbc:postgresql://localhost:5434/aipppc
DB_USER=aipppc
DB_PASS=aipppc

# --- Auth ---
# Must be >= 256 bits. In production this represents the signing key behind the
# City's Angeleno Account (Auth0) / Okta SSO bridge.
JWT_SECRET=change-me-in-production-minimum-256-bits-long-secret-key-for-aip-ppc
JWT_EXPIRATION_MS=86400000

# --- AI-assisted analysis (Anthropic Claude) ---
# Optional. When blank, the pre-screening engine runs rules-only and the AI
# provider falls back to a deterministic heuristic so the app still works
# fully offline (tests never require a key). See docs/05-ai-and-governance.md.
ANTHROPIC_API_KEY=
ANTHROPIC_API_URL=https://api.anthropic.com/v1
ANTHROPIC_MODEL=claude-sonnet-4-6

# --- Bootstrap admin ---
# Email auto-promoted to STAFF + ADMIN at every boot (idempotent). Register this
# account first. After changing this value, recreate the container with
# `docker compose up -d backend` — a plain `docker compose restart` does NOT
# re-read .env. This compose-injected value overrides the application.yml default.
APP_BOOTSTRAP_ADMIN_EMAIL=admin@lacity.gov

# --- Storage ---
STORAGE_PATH=./storage

# --- Knowledgebase embeddings (vector retrieval arm) ---
# Optional TEI sidecar (intfloat/e5-large-v2). When unreachable the retriever
# degrades to lexical-only and screening is unaffected.
# macOS: brew install text-embeddings-inference && text-embeddings-router \
#          --model-id intfloat/e5-large-v2 --port 8086
# linux/amd64: docker compose --profile docker-tei up  (then EMBEDDING_URL=http://tei:80)
EMBEDDING_ENABLED=true
EMBEDDING_URL=http://localhost:8086
EMBEDDING_MODEL=intfloat/e5-large-v2
EMBEDDING_DIM=1024

# --- Knowledgebase refresh scheduler (SOW 2.2.13 monthly updates) ---
# Re-runs the corpus upsert (by external_id) + embedding backfill.
KB_SCHEDULER_ENABLED=false
KB_SCHEDULER_CRON=0 0 4 1 * *
